{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/block-memory-write.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/block-residue.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/block-underived-measurement.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/block-effort-estimate.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/block-unexplained-hedge.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/block-question-as-disagreement.sh"
          }
        ]
      }
    ]
  }
}
